[
  {
    "name": "ecommerce-infra",
    "kind": "infrastructure",
    "argoApplication": "ecommerce-infra",
    "deployments": [
      "postgres-db",
      "prometheus",
      "loki",
      "grafana"
    ]
  },
  {
    "name": "ecommerce-auth",
    "kind": "service",
    "repo": "https://github.com/ilhamzefer-sketch/ecommerce-auth.git",
    "argoApplication": "ecommerce-auth",
    "deployment": "ecommerce-auth-app",
    "service": "ecommerce-auth-service",
    "localPort": 18080,
    "servicePort": 8081,
    "urlPath": "/swagger-ui/index.html"
  },
  {
    "name": "ecommerce-shop",
    "kind": "service",
    "argoApplication": "ecommerce-shop",
    "deployment": "ecommerce-shop-app",
    "service": "ecommerce-shop-service",
    "localPort": 18082,
    "servicePort": 8082,
    "urlPath": "/actuator/health"
  },
  {
    "name": "ecommerce-product",
    "kind": "service",
    "argoApplication": "ecommerce-product",
    "deployment": "ecommerce-product-app",
    "service": "ecommerce-product-service",
    "localPort": 18083,
    "servicePort": 8083,
    "urlPath": "/actuator/health"
  },
  {
    "name": "ecommerce-api-gateway",
    "kind": "service",
    "repo": "https://github.com/ilhamzefer-sketch/ecommerce-api-gateway.git",
    "argoApplication": "ecommerce-api-gateway",
    "deployment": "ecommerce-api-gateway-app",
    "service": "ecommerce-api-gateway-service",
    "localPort": 18081,
    "servicePort": 8080,
    "urlPath": "/swagger-ui/index.html"
  },
  {
    "name": "ecommerce-ui",
    "kind": "service",
    "repo": "https://github.com/ilhamzefer-sketch/ecommerce-ui.git",
    "argoApplication": "ecommerce-ui",
    "deployment": "ecommerce-ui-app",
    "service": "ecommerce-ui-service",
    "localPort": 3000,
    "servicePort": 80,
    "urlPath": "/"
  }
]
